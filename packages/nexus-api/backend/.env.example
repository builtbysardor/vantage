# Backend Environment Variables
# Copy this file to .env and fill in the values.

# Server port (default: 3001)
PORT=3001

# Enable verbose request logging (uncomment to enable)
# VERBOSE=true

# Log level for the structured logger (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# CORS — comma-separated list of allowed Origin headers.
# Defaults to http://localhost:3000 if unset.
CORS_ORIGINS=http://localhost:3000

# API keys — comma-separated list. Required.
# Used by the frontend / operators for authenticated write endpoints
# (PATCH/POST/DELETE) via the `x-api-key` header.
API_KEYS=replace-me-with-a-strong-random-key

# Agent tokens — comma-separated list. Required.
# Used by remote agents to push metrics via the `x-agent-token` header.
AGENT_TOKENS=replace-me-with-a-strong-random-agent-token

# JWT secret — used to sign and verify login tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-strong-random-jwt-secret

# Admin credentials for the web UI login.
# ADMIN_USERNAME defaults to "admin" if unset.
# ADMIN_PASSWORD_HASH must be a bcrypt hash. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-me-with-bcrypt-hash-of-your-password

# ──────────────────────────────────────────────────────────────
# Remote agent configuration (only needed when running agent.js
# on a remote host)
# ──────────────────────────────────────────────────────────────
# NEXUS_SERVER=http://YOUR_SERVER_IP:3001
# HOST_ID=my-server
# AGENT_TOKEN=must-match-one-entry-in-AGENT_TOKENS-on-the-server
