# === Auth (unified) ===
VANTAGE_JWT_SECRET="generate-with-openssl-rand-base64-32"
VANTAGE_FRONTEND_URL="http://localhost:3000"

# === Nexus backend ===
NEXUS_PORT=3001
API_KEYS="change-me-api-key"
AGENT_TOKENS="change-me-agent-token"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""   # generate: node -e "require('bcryptjs').hash('yourpass',10).then(console.log)"

# === InfraWatch FastAPI ===
JWT_SECRET_KEY="${VANTAGE_JWT_SECRET}"
JWT_EXPIRE_MINUTES=480
ADMIN_PASSWORD="change-me"
VIEWER_PASSWORD="change-me"
PROMETHEUS_URL="http://prometheus:9090"
DB_ENABLED=true

# === PostgreSQL ===
POSTGRES_USER=infrawatch
POSTGRES_PASSWORD="change-me"
POSTGRES_DB=infrawatch

# === Redis ===
REDIS_URL="redis://redis:6379/0"

# === Infrastructure ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD="change-me"
PROMETHEUS_RETENTION=15d
