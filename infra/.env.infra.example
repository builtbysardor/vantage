# =============================================================
# InfraWatch — Environment Configuration
# Copy this file to .env.local for local overrides.
# Never commit real secrets to version control.
# =============================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=infrawatch

# Prometheus data retention period
PROMETHEUS_RETENTION=15d

# PostgreSQL (Phase 5)
POSTGRES_USER=infrawatch
POSTGRES_PASSWORD=infrawatch
POSTGRES_DB=infrawatch

# Redis (Phase 3)
REDIS_URL=redis://redis:6379/0

# JWT Auth (Phase 4) — change this in production!
JWT_SECRET_KEY=infrawatch-dev-secret-change-in-prod
JWT_EXPIRE_MINUTES=60

# Backend users (Phase 4)
ADMIN_PASSWORD=infrawatch
VIEWER_PASSWORD=viewer123
