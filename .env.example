# Nexus Pro — Environment Variables Reference
#
# Each service reads its own .env file. This top-level file is for
# documentation only — copy values into the per-service files below.
#
#   Backend  → backend/.env         (template: backend/.env.example)
#   Frontend → frontend/.env.local  (template: frontend/.env.local.example — TODO: add)
#
# ──────────────────────────────────────────────────────────────
# Backend (backend/.env)
# ──────────────────────────────────────────────────────────────
# PORT=3001
# VERBOSE=true
#
# Remote agent (only when running src/agents/agent.js on a remote host)
# NEXUS_SERVER=http://YOUR_SERVER_IP:3001
# HOST_ID=my-server
#
# ──────────────────────────────────────────────────────────────
# Frontend (frontend/.env.local)
# ──────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_WS_URL=ws://localhost:3001
